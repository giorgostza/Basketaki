@model Basketaki.Models.Player

@{
    ViewData["Title"] = "Player Details";
}

<h1 class="mb-4">Player Details</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h4 class="card-title mb-4">@Model.FullName</h4>

        <dl class="row">
            <dt class="col-sm-3">First Name</dt>
            <dd class="col-sm-9">@Model.FirstName</dd>

            <dt class="col-sm-3">Last Name</dt>
            <dd class="col-sm-9">@Model.LastName</dd>

            <dt class="col-sm-3">Date of Birth</dt>
            <dd class="col-sm-9">@Model.DateOfBirth.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Height</dt>
            <dd class="col-sm-9">@Model.Height cm</dd>

            <dt class="col-sm-3">Weight</dt>
            <dd class="col-sm-9">@Model.Weight kg</dd>

            <dt class="col-sm-3">Position</dt>
            <dd class="col-sm-9">@Model.Position</dd>

            <dt class="col-sm-3">Photo</dt>
            <dd class="col-sm-9">
                @if (string.IsNullOrWhiteSpace(Model.PhotoUrl))
                {
                    <span class="text-muted">No photo</span>
                }
                else
                {
                    <a href="@Model.PhotoUrl" target="_blank">Open Photo</a>
                }
            </dd>

            <dt class="col-sm-3">Registrations</dt>
            <dd class="col-sm-9">@Model.PlayerSeasonTeams.Count</dd>
        </dl>
    </div>
</div>

@if (Model.PlayerSeasonTeams.Any())
{
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h5 class="mb-3">Team History</h5>

            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>Team</th>
                        <th>Season</th>
                        <th>Join Date</th>
                        <th>Leave Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var registration in Model.PlayerSeasonTeams
                                    .OrderByDescending(pst => pst.Season.StartDate)
                                    .ThenBy(pst => pst.Team.Name))
                    {
                        <tr>
                            <td>@registration.Team.Name</td>
                            <td>@registration.Season.Name</td>
                            <td>@registration.JoinDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                @(registration.LeaveDate.HasValue
                                                        ? registration.LeaveDate.Value.ToString("dd/MM/yyyy")
                                                        : "Still Active")
                    </td>
                </tr>
                                }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
