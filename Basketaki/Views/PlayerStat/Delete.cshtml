@model Basketaki.Models.PlayerStat

@{
    ViewData["Title"] = "Delete Player Stat";
}

<h1 class="mb-4">Delete Player Stat</h1>

<partial name="_Alerts" />

<div class="card border-danger shadow-sm">
    <div class="card-body">
        <h4 class="text-danger">Are you sure you want to delete this player stat?</h4>
        <hr />

        <dl class="row">
            <dt class="col-sm-3">Player</dt>
            <dd class="col-sm-9">@Model.PlayerSeasonTeam.Player.FullName</dd>

            <dt class="col-sm-3">Team</dt>
            <dd class="col-sm-9">@Model.PlayerSeasonTeam.Team.Name</dd>

            <dt class="col-sm-3">Match Date</dt>
            <dd class="col-sm-9">@Model.Match.MatchDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Points</dt>
            <dd class="col-sm-9">@Model.Points</dd>

            <dt class="col-sm-3">Total Rebounds</dt>
            <dd class="col-sm-9">@Model.TotalRebounds</dd>

            <dt class="col-sm-3">Assists</dt>
            <dd class="col-sm-9">@Model.Assists</dd>

            <dt class="col-sm-3">MVP</dt>
            <dd class="col-sm-9">@(Model.IsMVP ? "Yes" : "No")</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" asp-route-matchId="@Model.MatchId" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>