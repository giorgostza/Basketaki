@model Basketaki.ViewModels.PlayerStatFormViewModel

@{
    ViewData["Title"] = "Create Player Stat";
}

<h1 class="mb-4">Create Player Stat</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <partial name="_Form" model="Model" />

            <div class="form-text mb-3">
                The selected player assignment must belong to one of the teams participating in the selected match.
            </div>

            <button type="submit" class="btn btn-primary">Create</button>
            <a asp-action="Index" asp-route-matchId="@Model.MatchId" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}