@model Basketaki.Models.PlayerStat

@{
    ViewData["Title"] = "Player Stat Details";
}

<h1 class="mb-4">Player Stat Details</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <h4 class="card-title mb-4">
            @Model.PlayerSeasonTeam.Player.FullName - @Model.Match.MatchDate.ToString("dd/MM/yyyy")
        </h4>

        <dl class="row">
            <dt class="col-sm-3">Player</dt>
            <dd class="col-sm-9">@Model.PlayerSeasonTeam.Player.FullName</dd>

            <dt class="col-sm-3">Team</dt>
            <dd class="col-sm-9">@Model.PlayerSeasonTeam.Team.Name</dd>

            <dt class="col-sm-3">Match Date</dt>
            <dd class="col-sm-9">@Model.Match.MatchDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Points</dt>
            <dd class="col-sm-9">@Model.Points</dd>

            <dt class="col-sm-3">Offensive Rebounds</dt>
            <dd class="col-sm-9">@Model.OffensiveRebounds</dd>

            <dt class="col-sm-3">Defensive Rebounds</dt>
            <dd class="col-sm-9">@Model.DefensiveRebounds</dd>

            <dt class="col-sm-3">Total Rebounds</dt>
            <dd class="col-sm-9">@Model.TotalRebounds</dd>

            <dt class="col-sm-3">Assists</dt>
            <dd class="col-sm-9">@Model.Assists</dd>

            <dt class="col-sm-3">Steals</dt>
            <dd class="col-sm-9">@Model.Steals</dd>

            <dt class="col-sm-3">Blocks</dt>
            <dd class="col-sm-9">@Model.Blocks</dd>

            <dt class="col-sm-3">Fouls</dt>
            <dd class="col-sm-9">@Model.Fouls</dd>

            <dt class="col-sm-3">Minutes Played</dt>
            <dd class="col-sm-9">@Model.MinutesPlayed</dd>

            <dt class="col-sm-3">Free Throws</dt>
            <dd class="col-sm-9">@Model.FreeThrowsMade / @Model.FreeThrowsAttempted</dd>

            <dt class="col-sm-3">Two Points</dt>
            <dd class="col-sm-9">@Model.TwoPointsMade / @Model.TwoPointsAttempted</dd>

            <dt class="col-sm-3">Three Points</dt>
            <dd class="col-sm-9">@Model.ThreePointsMade / @Model.ThreePointsAttempted</dd>

            <dt class="col-sm-3">MVP</dt>
            <dd class="col-sm-9">@(Model.IsMVP ? "Yes" : "No")</dd>

            <dt class="col-sm-3">Suspension Games</dt>
            <dd class="col-sm-9">@Model.SuspensionGames</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" asp-route-matchId="@Model.MatchId" class="btn btn-secondary">Back to List</a>
</div>