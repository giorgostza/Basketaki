@model IEnumerable<Basketaki.Models.Season>

@{
    ViewData["Title"] = "Seasons";
}

<h1 class="mb-4">Seasons</h1>

<partial name="_Alerts" />

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Season</a>
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No seasons found.
    </div>
}
else
{
    <table class="table table-bordered table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th class="text-center" style="width: 220px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var season in Model)
            {
                <tr>
                    <td>@season.Name</td>
                    <td>@season.StartDate.ToString("dd/MM/yyyy")</td>
                    <td>@season.EndDate.ToString("dd/MM/yyyy")</td>
                    <td class="text-center">
                        <a asp-action="Details" asp-route-id="@season.Id" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Edit" asp-route-id="@season.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@season.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}