@model IEnumerable<Basketaki.Models.Season>

@{
    ViewData["Title"] = "Index";
}

<h2>Seasons</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Season</a>
</p>


<table class="table table-bordered">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StartDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EndDate)
            </th>
            <th>
                Actions
            </th>
           
        </tr>
    </thead>
    <tbody>
@foreach (var season in Model) {
        <tr>
            <td>
                    @Html.DisplayFor(modelItem => season.Name)
            </td>
            <td>
                    @Html.DisplayFor(modelItem => season.StartDate.ToShortDateString())
            </td>
            <td>
                    @Html.DisplayFor(modelItem => season.EndDate.ToShortDateString())
            </td>
            <td>
                    <a asp-action="Edit" asp-route-id="@season.Id" class="btn btn-sm btn-warning">Edit</a> |
                    <a asp-action="Details" asp-route-id="@season.Id" class="btn btn-sm btn-info">Details</a> |
                    <a asp-action="Delete" asp-route-id="@season.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
