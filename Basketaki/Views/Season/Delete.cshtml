@model Basketaki.Models.Season

@{
    ViewData["Title"] = "Delete Season";
}

<h1 class="mb-4">Delete Season</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="card border-danger shadow-sm">
    <div class="card-body">
        <h4 class="text-danger">Are you sure you want to delete this season?</h4>
        <hr />

        <!-- ✅ WARNING ΕΔΩ -->
        @if (Model.Leagues.Any() || Model.PlayerSeasonTeams.Any())
        {
            <div class="alert alert-warning">
                This season is linked with leagues or player registrations and may not be deletable.
            </div>
        }

        <dl class="row">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Start Date</dt>
            <dd class="col-sm-9">@Model.StartDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">End Date</dt>
            <dd class="col-sm-9">@Model.EndDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Leagues Count</dt>
            <dd class="col-sm-9">@Model.Leagues.Count</dd>

            <dt class="col-sm-3">Player Registrations</dt>
            <dd class="col-sm-9">@Model.PlayerSeasonTeams.Count</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>