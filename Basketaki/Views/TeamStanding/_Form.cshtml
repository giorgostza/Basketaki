@model Basketaki.ViewModels.TeamStandingFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="mb-3">
    <label asp-for="TeamSeasonLeagueId" class="form-label"></label>
    <select asp-for="TeamSeasonLeagueId" asp-items="Model.TeamSeasonLeagues" class="form-select">
        <option value="">-- Select Team League Assignment --</option>
    </select>
    <span asp-validation-for="TeamSeasonLeagueId" class="text-danger"></span>
</div>

<div class="row">
    <div class="col-md-4 mb-3">
        <label asp-for="Played" class="form-label"></label>
        <input asp-for="Played" type="number" class="form-control" />
        <span asp-validation-for="Played" class="text-danger"></span>
    </div>

    <div class="col-md-4 mb-3">
        <label asp-for="Wins" class="form-label"></label>
        <input asp-for="Wins" type="number" class="form-control" />
        <span asp-validation-for="Wins" class="text-danger"></span>
    </div>

    <div class="col-md-4 mb-3">
        <label asp-for="Losses" class="form-label"></label>
        <input asp-for="Losses" type="number" class="form-control" />
        <span asp-validation-for="Losses" class="text-danger"></span>
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-3">
        <label asp-for="PointsFor" class="form-label"></label>
        <input asp-for="PointsFor" type="number" class="form-control" />
        <span asp-validation-for="PointsFor" class="text-danger"></span>
    </div>

    <div class="col-md-4 mb-3">
        <label asp-for="PointsAgainst" class="form-label"></label>
        <input asp-for="PointsAgainst" type="number" class="form-control" />
        <span asp-validation-for="PointsAgainst" class="text-danger"></span>
    </div>

    <div class="col-md-4 mb-3">
        <label asp-for="LeaguePoints" class="form-label"></label>
        <input asp-for="LeaguePoints" type="number" class="form-control" />
        <span asp-validation-for="LeaguePoints" class="text-danger"></span>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <label asp-for="NoShow" class="form-label"></label>
        <input asp-for="NoShow" type="number" class="form-control" />
        <span asp-validation-for="NoShow" class="text-danger"></span>
    </div>

    <div class="col-md-6 mb-3">
        <label asp-for="CurrentStreak" class="form-label"></label>
        <input asp-for="CurrentStreak" type="number" class="form-control" />
        <span asp-validation-for="CurrentStreak" class="text-danger"></span>
    </div>
</div>