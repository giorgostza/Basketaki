@model Basketaki.Models.TeamStanding

@{
    ViewData["Title"] = "Delete Standing";
}

<h1 class="mb-4">Delete Standing</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="card border-danger shadow-sm">
    <div class="card-body">
        <h4 class="text-danger">Are you sure you want to delete this standing?</h4>
        <hr />

        <dl class="row">
            <dt class="col-sm-3">Team</dt>
            <dd class="col-sm-9">@Model.TeamSeasonLeague.Team.Name</dd>

            <dt class="col-sm-3">League</dt>
            <dd class="col-sm-9">@Model.TeamSeasonLeague.League.Name</dd>

            <dt class="col-sm-3">Played</dt>
            <dd class="col-sm-9">@Model.Played</dd>

            <dt class="col-sm-3">Wins</dt>
            <dd class="col-sm-9">@Model.Wins</dd>

            <dt class="col-sm-3">Losses</dt>
            <dd class="col-sm-9">@Model.Losses</dd>

            <dt class="col-sm-3">League Points</dt>
            <dd class="col-sm-9">@Model.LeaguePoints</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>