@model Basketaki.Models.Referee

@{
    ViewData["Title"] = "Referee Details";
}

<h1 class="mb-4">Referee Details</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h4 class="card-title mb-4">@Model.FullName</h4>

        <dl class="row">
            <dt class="col-sm-3">First Name</dt>
            <dd class="col-sm-9">@Model.FirstName</dd>

            <dt class="col-sm-3">Last Name</dt>
            <dd class="col-sm-9">@Model.LastName</dd>

            <dt class="col-sm-3">Date of Birth</dt>
            <dd class="col-sm-9">@Model.DateOfBirth.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Height</dt>
            <dd class="col-sm-9">@Model.Height cm</dd>

            <dt class="col-sm-3">Photo</dt>
            <dd class="col-sm-9">
                @if (string.IsNullOrWhiteSpace(Model.PhotoUrl))
                {
                    <span class="text-muted">No photo</span>
                }
                else
                {
                    <a href="@Model.PhotoUrl" target="_blank">Open Photo</a>
                }
            </dd>

            <dt class="col-sm-3">Assigned Matches</dt>
            <dd class="col-sm-9">@Model.MatchReferees.Count</dd>
        </dl>
    </div>
</div>

@if (Model.MatchReferees.Any())
{
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h5 class="mb-3">Matches</h5>

            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>Match Id</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.MatchReferees.OrderBy(mr => mr.Match.MatchDate))
                    {
                        <tr>
                            <td>@item.Match.Id</td>
                            <td>@item.Match.MatchDate.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
