@model Basketaki.Models.Referee

@{
    ViewData["Title"] = "Delete Referee";
}

<h1 class="mb-4">Delete Referee</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="card border-danger shadow-sm">
    <div class="card-body">
        <h4 class="text-danger">Are you sure you want to delete this referee?</h4>
        <hr />

        @if (Model.MatchReferees.Any())
        {
            <div class="alert alert-warning">
                This referee is assigned to one or more matches and may not be deletable.
            </div>
        }

        <dl class="row">
            <dt class="col-sm-3">First Name</dt>
            <dd class="col-sm-9">@Model.FirstName</dd>

            <dt class="col-sm-3">Last Name</dt>
            <dd class="col-sm-9">@Model.LastName</dd>

            <dt class="col-sm-3">Date of Birth</dt>
            <dd class="col-sm-9">@Model.DateOfBirth.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Height</dt>
            <dd class="col-sm-9">@Model.Height cm</dd>

            <dt class="col-sm-3">Photo</dt>
            <dd class="col-sm-9">
                @if (string.IsNullOrWhiteSpace(Model.PhotoUrl))
                {
                    <span class="text-muted">No photo</span>
                }
                else
                {
                    <a href="@Model.PhotoUrl" target="_blank">Open Photo</a>
                }
            </dd>

            <dt class="col-sm-3">Assigned Matches</dt>
            <dd class="col-sm-9">@Model.MatchReferees.Count</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
