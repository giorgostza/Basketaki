@model Basketaki.Models.MatchPhoto

@{
    ViewData["Title"] = "Delete Match Photo";
}

<h1 class="mb-4">Delete Match Photo</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="card border-danger shadow-sm">
    <div class="card-body">
        <h4 class="text-danger">Are you sure you want to delete this photo?</h4>
        <hr />

        <div class="mb-4">
            <img src="@Model.ImageUrl"
                 alt="Match Photo"
                 class="img-fluid rounded border"
                 style="max-height:400px;" />
        </div>

        <dl class="row">
            <dt class="col-sm-3">Image URL</dt>
            <dd class="col-sm-9">
                <a href="@Model.ImageUrl" target="_blank">@Model.ImageUrl</a>
            </dd>

            <dt class="col-sm-3">Created At</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3">Match Id</dt>
            <dd class="col-sm-9">@Model.MatchId</dd>

            <dt class="col-sm-3">Match Date</dt>
            <dd class="col-sm-9">@Model.Match.MatchDate.ToString("dd/MM/yyyy")</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" asp-route-matchId="@Model.MatchId" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
