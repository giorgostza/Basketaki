@@model Basketaki.Models.MatchPhoto

@{
    ViewData["Title"] = "Photo Details";
}

<h1 class="mb-4">Photo Details</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <h4 class="card-title mb-4">Match Photo</h4>

        <div class="mb-4">
            <img src="@Model.ImageUrl"
                 alt="Match Photo"
                 class="img-fluid rounded border"
                 style="max-height:400px;" />
        </div>

        <dl class="row">
            <dt class="col-sm-3">Image URL</dt>
            <dd class="col-sm-9">
                <a href="@Model.ImageUrl" target="_blank">@Model.ImageUrl</a>
            </dd>

            <dt class="col-sm-3">Created At</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3">Match Id</dt>
            <dd class="col-sm-9">@Model.MatchId</dd>

            <dt class="col-sm-3">Match Date</dt>
            <dd class="col-sm-9">@Model.Match.MatchDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Match</dt>
            <dd class="col-sm-9">
                <a asp-controller="Match" asp-action="Details" asp-route-id="@Model.MatchId">
                    View Match Details
                </a>
            </dd>

        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" asp-route-matchId="@Model.MatchId" class="btn btn-secondary">Back to List</a>
</div>
