@model Basketaki.Models.Team

@{
    ViewData["Title"] = "Delete Team";
}

<h1 class="mb-4">Delete Team</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="card border-danger shadow-sm">
    <div class="card-body">
        <h4 class="text-danger">Are you sure you want to delete this team?</h4>
        <hr />

        @if (Model.TeamSeasonLeagues.Any() || Model.PlayerSeasonTeams.Any())
        {
            <div class="alert alert-warning">
                This team is linked with leagues or players and may not be deletable.
            </div>
        }

        <dl class="row">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">City</dt>
            <dd class="col-sm-9">@Model.City</dd>

            <dt class="col-sm-3">Coach</dt>
            <dd class="col-sm-9">
                @(Model.Coach != null ? Model.Coach.FullName : "No Coach")
            </dd>

            <dt class="col-sm-3">Photo</dt>
            <dd class="col-sm-9">
                @if (string.IsNullOrWhiteSpace(Model.PhotoUrl))
                {
                    <span class="text-muted">No photo</span>
                }
                else
                {
                    <a href="@Model.PhotoUrl" target="_blank">Open Photo</a>
                }
            </dd>

            <dt class="col-sm-3">League Participations</dt>
            <dd class="col-sm-9">@Model.TeamSeasonLeagues.Count</dd>

            <dt class="col-sm-3">Player Registrations</dt>
            <dd class="col-sm-9">@Model.PlayerSeasonTeams.Count</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>