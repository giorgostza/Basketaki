@model Basketaki.ViewModels.TeamFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="mb-3">
    <label asp-for="Name" class="form-label"></label>
    <input asp-for="Name" class="form-control" />
    <span asp-validation-for="Name" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="City" class="form-label"></label>
    <input asp-for="City" class="form-control" />
    <span asp-validation-for="City" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="PhotoUrl" class="form-label"></label>
    <input asp-for="PhotoUrl" type="url" class="form-control" />
    <span asp-validation-for="PhotoUrl" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="CoachId" class="form-label"></label>
    <select asp-for="CoachId" asp-items="Model.Coaches" class="form-select"></select>
    <span asp-validation-for="CoachId" class="text-danger"></span>
</div>
