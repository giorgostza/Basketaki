@model IEnumerable<Basketaki.Models.TeamSeasonLeague>

@{
    ViewData["Title"] = "Team League Assignments";
}

<h1 class="mb-4">Team League Assignments</h1>

<partial name="_Alerts" />

<p>
    <a asp-action="Create" class="btn btn-primary">Assign Team to League</a>
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No team league assignments found.
    </div>
}
else
{
    <table class="table table-bordered table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Team</th>
                <th>League</th>
                <th>City</th>
                <th>Season</th>
                <th class="text-center" style="width:180px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var assignment in Model)
            {
                <tr>
                    <td>@assignment.Team.Name</td>
                    <td>@assignment.League.Name</td>
                    <td>@assignment.League.City</td>
                    <td>@assignment.League.Season.Name</td>
                    <td class="text-center">
                        <a asp-action="Details" asp-route-id="@assignment.Id" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Delete" asp-route-id="@assignment.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}