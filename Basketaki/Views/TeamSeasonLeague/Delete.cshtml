@model Basketaki.Models.TeamSeasonLeague

@{
    ViewData["Title"] = "Delete Assignment";
}

<h1 class="mb-4">Delete Assignment</h1>

<partial name="_Alerts" />

<div class="card border-danger shadow-sm">
    <div class="card-body">
        <h4 class="text-danger">Are you sure you want to delete this assignment?</h4>
        <hr />

        <div class="alert alert-warning">
            This assignment may not be deletable if matches, players, or standings are linked to it.
        </div>

        <dl class="row">
            <dt class="col-sm-3">Team</dt>
            <dd class="col-sm-9">@Model.Team.Name</dd>

            <dt class="col-sm-3">League</dt>
            <dd class="col-sm-9">@Model.League.Name</dd>

            <dt class="col-sm-3">League City</dt>
            <dd class="col-sm-9">@Model.League.City</dd>

            <dt class="col-sm-3">Season</dt>
            <dd class="col-sm-9">@Model.League.Season.Name</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>