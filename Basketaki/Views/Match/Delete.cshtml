@model Basketaki.Models.Match

@{
    ViewData["Title"] = "Delete Match";
}

<h1 class="mb-4">Delete Match</h1>

<partial name="_Alerts" />

<div class="card border-danger shadow-sm">
    <div class="card-body">
        <h4 class="text-danger">Are you sure you want to delete this match?</h4>
        <hr />

        @if (Model.PlayerStats.Any() || Model.Photos.Any() || Model.MatchReferees.Any() )
        {

            <partial name="_DeleteWarning" model='"This match is linked with related data and may not be deletable."' />
            
        }

        <dl class="row">
            <dt class="col-sm-3">Date</dt>
            <dd class="col-sm-9">@Model.MatchDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Time</dt>
            <dd class="col-sm-9">@Model.StartTime - @Model.EndTime</dd>

            <dt class="col-sm-3">Court</dt>
            <dd class="col-sm-9">@Model.Court.Name</dd>

            <dt class="col-sm-3">League</dt>
            <dd class="col-sm-9">@Model.League.Name</dd>

            <dt class="col-sm-3">Home Team</dt>
            <dd class="col-sm-9">@Model.HomeTeamSeasonLeague.Team.Name</dd>

            <dt class="col-sm-3">Away Team</dt>
            <dd class="col-sm-9">@Model.AwayTeamSeasonLeague.Team.Name</dd>

            <dt class="col-sm-3">Played</dt>
            <dd class="col-sm-9">@(Model.IsPlayed ? "Yes" : "No")</dd>

            <dt class="col-sm-3">Score</dt>
            <dd class="col-sm-9">
                @if (Model.IsPlayed && Model.HomeScore.HasValue && Model.AwayScore.HasValue)
                {
                    <span>@Model.HomeScore - @Model.AwayScore</span>
                }
                else
                {
                    <span class="text-muted">No score available</span>
                }
            </dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
