@model IEnumerable<Basketaki.Models.Court>

@{
    ViewData["Title"] = "Courts";
}

<h1 class="mb-4">Courts</h1>


<partial name="_Alerts" />


<p>
    <a asp-action="Create" class="btn btn-primary">Create New Court</a>
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No courts found.
    </div>
}
else
{
    <table class="table table-bordered table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Location</th>
                <th>Description</th>
                <th class="text-center" style="width: 220px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var court in Model)
            {
                <tr>
                    <td>@court.Name</td>
                    <td>@court.Location</td>
                    <td>
                        @if (string.IsNullOrWhiteSpace(court.Description))
                        {
                            <span class="text-muted">No description</span>
                        }
                        else
                        {
                            @court.Description
                        }
                    </td>
                    <td class="text-center">
                        <a asp-action="Details" asp-route-id="@court.Id" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Edit" asp-route-id="@court.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@court.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}