@model Basketaki.Models.League

@{
    ViewData["Title"] = "Delete League";
}

<h1 class="mb-4">Delete League</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="card border-danger shadow-sm">
    <div class="card-body">
        <h4 class="text-danger">Are you sure you want to delete this league?</h4>
        <hr />

        @if (Model.TeamSeasonLeagues.Any() || Model.Matches.Any())
        {
            <div class="alert alert-warning">
                This league has assigned teams or matches and may not be deletable.
            </div>
        }

        <dl class="row">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">City</dt>
            <dd class="col-sm-9">@Model.City</dd>

            <dt class="col-sm-3">Season</dt>
            <dd class="col-sm-9">@Model.Season.Name</dd>

            <dt class="col-sm-3">Assigned Teams</dt>
            <dd class="col-sm-9">@Model.TeamSeasonLeagues.Count</dd>

            <dt class="col-sm-3">Matches</dt>
            <dd class="col-sm-9">@Model.Matches.Count</dd> 

        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>