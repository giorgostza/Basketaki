@model Basketaki.Models.PlayerSeasonTeam

@{
    ViewData["Title"] = "Delete Player Assignment";
}

<h1 class="mb-4">Delete Player Assignment</h1>

<partial name="_Alerts" />

<div class="card border-danger shadow-sm">
    <div class="card-body">
        <h4 class="text-danger">Are you sure you want to delete this assignment?</h4>
        <hr />

        @if (Model.PlayerStats.Any())
        {
            <partial name="_DeleteWarning" model='"This assignment has player stats and may not be deletable."' />
           
        }

        <dl class="row">
            <dt class="col-sm-3">Player</dt>
            <dd class="col-sm-9">@Model.Player.FullName</dd>

            <dt class="col-sm-3">Team</dt>
            <dd class="col-sm-9">@Model.Team.Name</dd>

            <dt class="col-sm-3">Season</dt>
            <dd class="col-sm-9">@Model.Season.Name</dd>

            <dt class="col-sm-3">Jersey Number</dt>
            <dd class="col-sm-9">#@Model.JerseyNumber</dd>

            <dt class="col-sm-3">Join Date</dt>
            <dd class="col-sm-9">@Model.JoinDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Leave Date</dt>
            <dd class="col-sm-9">
                @(Model.LeaveDate.HasValue
                                ? Model.LeaveDate.Value.ToString("dd/MM/yyyy")
                                : "Still Active")
            </dd>

            <dt class="col-sm-3">Player Stats Count</dt>
            <dd class="col-sm-9">@Model.PlayerStats.Count</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>